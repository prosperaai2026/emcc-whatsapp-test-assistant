# Porta do servidor
PORT=3000

# Caminho do banco SQLite
DATABASE_PATH=./data/church.db

# Google Calendar API
# Crie um projeto no Google Cloud Console, habilite a API do Google Calendar
# e gere uma Service Account Key (JSON). Coloque o conteúdo no arquivo
# referenciado abaixo ou configure as variáveis individuais.
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# OU (alternativa):
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_CALENDAR_ID= (ex: igreja@gmail.com - o email do calendário compartilhado)

# ID do calendário da igreja (endereço de email do calendário no Google Calendar)
CALENDAR_ID=your-church-calendar-id@group.calendar.google.com

# CORS (separar múltiplas origens com vírgula)
CORS_ORIGINS=*